# Supabase — find both under Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: override the product name shown in the UI (defaults to CampaignDesk)
# NEXT_PUBLIC_PRODUCT_NAME=CampaignDesk

# Which organization's published articles & leads power the public site
# (/, /blog, lead form). Use the org's slug; leave empty to use the
# oldest organization in the database.
# NEXT_PUBLIC_SITE_ORG_SLUG=wide-link-limited

# Canonical site URL — used in sitemap.xml, robots.txt, Open Graph and
# structured data. Set to your real domain in production.
# NEXT_PUBLIC_SITE_URL=https://m-n-sable.vercel.app
